</main>
<footer class="footer has-background-grey-lighter is-hidden-print mt-4">
  <div class="container is-fullhd">
    <div class="content has-text-right has-text-grey-dark">
      <strong>
        <%= configFunctions.getConfigProperty("application.applicationName") %>
      </strong><br />
      <span class="is-size-7">
        Build
        <a
          class="has-text-grey-dark"
          href="https://github.com/cityssm/shiftlog/releases/tag/v<%= buildNumber %>"
          rel="noreferrer noopener"
          target="_blank"
        >
          v<%= buildNumber %>
        </a>
        <% if (configFunctions.getConfigProperty('application.instance') !== '') { %>
        (<%= configFunctions.getConfigProperty('application.instance') %>)
        <% } %>
      </span>
    </div>
  </div>
</footer>
<script>
  globalThis.exports = globalThis.exports || {};

  globalThis.exports.shiftLog = {
    urlPrefix: "<%= urlPrefix %>",
    sessionKeepAliveMillis: <%- JSON.stringify(configFunctions.getConfigProperty('session.doKeepAlive') ? configFunctions.keepAliveMillis : 0) %>,
    apiKey: <%- JSON.stringify(user.userSettings.apiKey) %>,

    defaultLatitude: <%- JSON.stringify(await settingFunctions.getSettingValue('locations.defaultLatitude')) %>,
    defaultLongitude: <%- JSON.stringify(await settingFunctions.getSettingValue('locations.defaultLongitude')) %>,
    defaultCityProvince: <%- JSON.stringify(await settingFunctions.getSettingValue('locations.defaultCityProvince')) %>,

    shiftsAreEnabled: <%- JSON.stringify(configFunctions.getConfigProperty('shifts.isEnabled')) %>,
    shiftsRouter: <%- JSON.stringify(configFunctions.getConfigProperty('shifts.router')) %>,
    shiftsSectionName: <%- JSON.stringify(configFunctions.getConfigProperty('shifts.sectionName')) %>,
    shiftsSectionNameSingular: <%- JSON.stringify(configFunctions.getConfigProperty('shifts.sectionNameSingular')) %>,

    workOrdersAreEnabled: <%- JSON.stringify(configFunctions.getConfigProperty('workOrders.isEnabled')) %>,
    workOrdersRouter: <%- JSON.stringify(configFunctions.getConfigProperty('workOrders.router')) %>,
    workOrdersSectionName: <%- JSON.stringify(configFunctions.getConfigProperty('workOrders.sectionName')) %>,
    workOrdersSectionNameSingular: <%- JSON.stringify(configFunctions.getConfigProperty('workOrders.sectionNameSingular')) %>,
    workOrdersIconClass: <%- JSON.stringify(configFunctions.getConfigProperty('workOrders.iconClass')) %>,

    timesheetsAreEnabled: <%- JSON.stringify(configFunctions.getConfigProperty('timesheets.isEnabled')) %>,
    timesheetsRouter: <%- JSON.stringify(configFunctions.getConfigProperty('timesheets.router')) %>,
    timesheetsSectionName: <%- JSON.stringify(configFunctions.getConfigProperty('timesheets.sectionName')) %>,
    timesheetsSectionNameSingular: <%- JSON.stringify(configFunctions.getConfigProperty('timesheets.sectionNameSingular')) %>,

    isAdmin: <%- JSON.stringify(user.userProperties.isAdmin) %>,
    userName: <%- JSON.stringify(user.userName) %>,
    userCanManageWorkOrders: <%- JSON.stringify(user.userProperties.workOrders.canManage) %>,
    userCanUpdateWorkOrders: <%- JSON.stringify(user.userProperties.workOrders.canUpdate) %>
  };
</script>
