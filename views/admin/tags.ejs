<%- await include('../_header'); -%>

<div class="columns is-mobile">
  <div class="column is-2-desktop is-narrow-touch is-hidden-print">
    <%- await include('_menu'); -%>
  </div>
  <div class="column">
    <div class="columns is-mobile is-vcentered">
      <div class="column">
        <nav class="breadcrumb">
          <ul>
            <li><a href="<%= urlPrefix %>/dashboard">Home</a></li>
            <li>
              <a href="#">
                <span class="icon is-small">
                  <i class="fa-solid fa-cog"></i>
                </span>
                <span>Administrator Tools</span>
              </a>
            </li>
            <li class="is-active">
              <a href="#" aria-current="page"> Tag Management </a>
            </li>
          </ul>
        </nav>
      </div>
      <div class="column is-narrow">
        <a
          class="is-size-7"
          href="https://cityssm.github.io/shiftlog/docs/adminTags.html"
          rel="noopener noreferrer"
          target="_blank"
        >
          <span class="icon is-small">
            <i class="fa-solid fa-question-circle"></i>
          </span>
          <span>Help</span>
        </a>
      </div>
    </div>

    <h1 class="title is-1">Tag Management</h1>

    <div class="tabs is-boxed">
      <ul>
        <li class="is-active">
          <a href="#tab-tags">
            <span class="icon">
              <i class="fa-solid fa-tags"></i>
            </span>
            <span>Tags</span>
          </a>
        </li>
        <li>
          <a href="#tab-tagAliases">
            <span class="icon">
              <i class="fa-solid fa-list"></i>
            </span>
            <span>Tag Aliases</span>
          </a>
        </li>
      </ul>
    </div>

    <div id="tab-tags">
      <div class="columns is-vcentered">
        <div class="column">
          <div class="message is-info">
            <div class="message-body">
              Create and manage color-coded tags for categorizing and organizing <%= configFunctions.getConfigProperty('workOrders.sectionName').toLowerCase() %>.
              Configure custom colors for visual identification and promote ad-hoc tags to system tags.
            </div>
          </div>
        </div>
        <div class="column is-narrow">
          <div class="field">
            <div class="control has-icons-left">
              <input
                class="input"
                id="filter--tags"
                type="text"
                aria-label="Filter tags"
                placeholder="Filter tags..."
              />
              <span class="icon is-small is-left">
                <i class="fa-solid fa-magnifying-glass"></i>
              </span>
            </div>
          </div>
        </div>
        <div class="column is-narrow">
          <div class="field has-addons">
            <div class="control">
              <button class="button is-success" id="button--addTag" type="button">
                <span class="icon">
                  <i class="fa-solid fa-plus"></i>
                </span>
                <span>Add Tag</span>
              </button>
            </div>
            <div class="control">
              <div class="dropdown is-right">
                <div class="dropdown-trigger">
                  <button class="button is-success" type="button">
                    <span class="icon">
                      <i class="fa-solid fa-angle-down"></i>
                    </span>
                  </button>
                </div>
                <div class="dropdown-menu">
                  <div class="dropdown-content">
                    <a
                      class="dropdown-item"
                      id="button--addUsedTags"
                      href="#"
                    >
                      <span class="icon">
                        <i class="fa-solid fa-file-import"></i>
                      </span>
                      <span>
                        Add Used Tags
                      </span>
                    </a>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
      <div id="container--tags"></div>
    </div>
    <div class="is-hidden" id="tab-tagAliases">
      <div class="columns is-vcentered">
        <div class="column">
          <div class="message is-info">
            <div class="message-body">
              Map alternate terms to a related tag. When a mapped alias is added to a <%= configFunctions.getConfigProperty('workOrders.sectionNameSingular').toLowerCase() %>, the related tag will be stored instead.
            </div>
          </div>
        </div>
        <div class="column is-narrow">
          <div class="field">
            <div class="control has-icons-left">
              <input
                class="input"
                id="filter--tagAliases"
                type="text"
                aria-label="Filter tag aliases"
                placeholder="Filter aliases..."
              />
              <span class="icon is-small is-left">
                <i class="fa-solid fa-magnifying-glass"></i>
              </span>
            </div>
          </div>
        </div>
        <div class="column is-narrow">
          <button
            class="button is-success"
            id="button--addTagAlias"
            type="button"
          >
            <span class="icon">
              <i class="fa-solid fa-plus"></i>
            </span>
            <span>Add Tag Alias</span>
          </button>
        </div>
      </div>

      <div id="container--tagAliases"></div>
    </div>
    <datalist id="tagNameSuggestions"></datalist>
  </div>
</div>

<%- await include('../_footerA'); -%>

<script>
  exports.tags = <%- JSON.stringify(tags) %>;
  exports.tagAliases = <%- JSON.stringify(tagAliases) %>;
</script>
<script src="<%= urlPrefix %>/javascripts/tags.admin.js"></script>

<%- await include('../_footerB'); -%>
