<%- await include('../_header'); -%>

<div class="columns is-mobile">
  <div class="column is-2-desktop is-narrow-touch is-hidden-print">
    <%- await include('_menu'); -%>
  </div>
  <div class="column">
    <div class="columns is-mobile is-vcentered">
      <div class="column">
        <nav class="breadcrumb">
          <ul>
            <li><a href="<%= urlPrefix %>/dashboard">Home</a></li>
            <li>
              <a href="#">
                <span class="icon is-small">
                  <i class="fa-solid fa-cog"></i>
                </span>
                <span>Administrator Tools</span>
              </a>
            </li>
            <li class="is-active">
              <a href="#" aria-current="page"> Ignored Attachment Management </a>
            </li>
          </ul>
        </nav>
      </div>
    </div>

    <h1 class="title is-1">Ignored Attachment Management</h1>

    <div class="message is-info">
      <div class="message-body">
        Manage checksums of attachments that should be ignored in future imports.
        Remove checksums from this list to resume normal attachment processing.
      </div>
    </div>

    <div id="container--ignoredAttachments">
      <% if (ignoredAttachmentChecksums.length === 0) { %>
      <div class="message is-info" id="message--noIgnoredAttachments">
        <div class="message-body">
          There are no ignored attachment checksums.
        </div>
      </div>
      <% } else { %>
      <table class="table is-striped is-hoverable is-fullwidth">
        <thead>
          <tr>
            <th>Checksum</th>
            <th>Note</th>
            <th>Updated By</th>
            <th>Updated On</th>
            <th>
              <span class="is-sr-only">Actions</span>
            </th>
          </tr>
        </thead>
        <tbody>
          <% for (const ignoredAttachment of ignoredAttachmentChecksums) { %>
          <tr data-file-checksum="<%= ignoredAttachment.fileChecksum %>">
            <td>
              <code><%= ignoredAttachment.fileChecksum %></code>
            </td>
            <td><%= ignoredAttachment.noteText %></td>
            <td><%= ignoredAttachment.recordUpdate_userName %></td>
            <td><%= dateTimeFunctions.dateToString(ignoredAttachment.recordUpdate_dateTime) %></td>
            <td class="has-text-right">
              <button
                class="button is-small is-danger button--deleteIgnoredAttachment"
                data-file-checksum="<%= ignoredAttachment.fileChecksum %>"
                type="button"
              >
                <span class="icon is-small">
                  <i class="fa-solid fa-trash"></i>
                </span>
                <span>Remove</span>
              </button>
            </td>
          </tr>
          <% } %>
        </tbody>
      </table>
      <% } %>
    </div>
  </div>
</div>

<%- await include('../_footerA'); -%>

<script src="<%= urlPrefix %>/javascripts/ignoredAttachments.admin.js"></script>

<%- await include('../_footerB'); -%>
