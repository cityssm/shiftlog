<div class="columns is-mobile">
  <div class="column">
    <h2 class="title is-4">Subscribers</h2>
  </div>
  <% if (isEdit) { %>
  <div class="column is-narrow has-text-right">
    <button class="button is-small is-success" id="button--addSubscriber" type="button">
      <span class="icon"><i class="fa-solid fa-plus"></i></span>
      <span>Add Subscriber</span>
    </button>
  </div>
  <% } %>
</div>

<% if (isEdit && configFunctions.getConfigProperty('connectors.msGraph') === undefined) { %>
<div class="message is-warning">
  <p>Microsoft Graph connector is not configured.</p>
</div>
<% } %>

<div id="container--subscribers">
  <!-- Subscribers will be loaded here -->
</div>
